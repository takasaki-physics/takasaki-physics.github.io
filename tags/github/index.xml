width="1365"
height="564"
srcset="https://takasaki-physics.github.io/p/20240219-discuss/discussions_hu5613945052622931508.png 480w, https://takasaki-physics.github.io/p/20240219-discuss/discussions_hu4480379505570933460.png 1024w"
loading="lazy"
